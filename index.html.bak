<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Inventario Diego Culajay</title>
    <link rel="manifest" href="manifest.json">
    <meta name="theme-color" content="#10b981">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    },
                    colors: {
                        brand: {
                            50: '#ecfdf5',
                            100: '#d1fae5',
                            500: '#10b981',
                            600: '#059669',
                            900: '#064e3b',
                        },
                        status: {
                            safe: '#10b981', // green
                            warning: '#f59e0b', // yellow
                            danger: '#ef4444' // red
                        }
                    }
                }
            }
        }
    </script>

    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="style.css">
</head>

<body
    class="bg-gray-50 text-gray-800 dark:bg-gray-900 dark:text-gray-100 transition-colors duration-200 antialiased pb-safe">

    <!-- Header -->
    <header
        class="sticky top-0 z-30 bg-white/80 dark:bg-gray-800/80 backdrop-blur-md border-b border-gray-200 dark:border-gray-700 shadow-sm transition-colors duration-200">
        <div class="container mx-auto px-4 h-16 flex items-center justify-between">
            <div class="flex items-center gap-2 text-brand-500">
                <i class="fa-solid fa-box-open text-2xl drop-shadow-sm"></i>
                <h1 class="font-bold text-xl tracking-tight hidden sm:block text-gray-900 dark:text-white">Inventario
                    Doméstico</h1>
                <h1 class="font-bold text-xl tracking-tight sm:hidden text-gray-900 dark:text-white">Inventario</h1>
            </div>
            <div class="flex items-center gap-4">
                <button id="theme-toggle"
                    class="p-2 w-10 h-10 flex items-center justify-center rounded-full hover:bg-gray-100 dark:hover:bg-gray-700 transition">
                    <i class="fa-solid fa-moon text-xl dark:hidden text-gray-600"></i>
                    <i class="fa-solid fa-sun text-xl hidden dark:block text-yellow-400"></i>
                </button>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="container mx-auto px-4 py-6 max-w-5xl mb-20" id="app-content">
        <!-- View: Dashboard -->
        <section id="view-dashboard" class="view-section block animate-fade-in">
            <div class="mb-6">
                <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Resumen Mensual</h2>
                <p class="text-gray-600 dark:text-gray-400 text-sm">Monitorea el estado general de tus productos</p>
            </div>

            <!-- Stats Grid -->
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
                <div
                    class="bg-white dark:bg-gray-800 rounded-2xl p-4 shadow-sm border border-gray-100 dark:border-gray-700 flex flex-col justify-center items-center text-center transform transition-transform hover:scale-105">
                    <span class="text-gray-500 dark:text-gray-400 text-sm font-medium mb-1">Total Registrados</span>
                    <span class="text-3xl font-bold text-blue-500" id="stat-total">0</span>
                </div>
                <div
                    class="bg-white dark:bg-gray-800 rounded-2xl p-4 shadow-sm border border-green-100 dark:border-green-900/40 flex flex-col justify-center items-center text-center transform transition-transform hover:scale-105">
                    <span class="text-green-600 dark:text-green-400 text-sm font-medium mb-1">Seguros (>7 días)</span>
                    <span class="text-3xl font-bold text-status-safe" id="stat-safe">0</span>
                </div>
                <div
                    class="bg-white dark:bg-gray-800 rounded-2xl p-4 shadow-sm border border-yellow-100 dark:border-yellow-900/40 flex flex-col justify-center items-center text-center transform transition-transform hover:scale-105">
                    <span class="text-yellow-600 dark:text-yellow-400 text-sm font-medium mb-1">Próximos (≤7
                        días)</span>
                    <span class="text-3xl font-bold text-status-warning" id="stat-warning">0</span>
                </div>
                <div
                    class="bg-white dark:bg-gray-800 rounded-2xl p-4 shadow-sm border border-red-100 dark:border-red-900/40 flex flex-col justify-center items-center text-center transform transition-transform hover:scale-105">
                    <span class="text-red-500 dark:text-red-400 text-sm font-medium mb-1">Vencidas</span>
                    <span class="text-3xl font-bold text-status-danger" id="stat-danger">0</span>
                </div>
            </div>

            <!-- Alerts Panel -->
            <div
                class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 mb-8 overflow-hidden">
                <div
                    class="bg-gray-50 dark:bg-gray-900/50 px-4 py-3 border-b border-gray-100 dark:border-gray-700 flex justify-between items-center">
                    <h3 class="font-semibold text-gray-800 dark:text-white flex items-center gap-2">
                        <i class="fa-solid fa-bell text-status-warning animate-pulse"></i> Alertas de Vencimiento
                    </h3>
                </div>
                <div class="p-0" id="alerts-container">
                    <!-- Alerts injected here -->
                    <div class="text-center text-gray-400 py-6 italic text-sm">Escaneando estado...</div>
                </div>
            </div>

            <!-- Charts -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div
                    class="bg-white dark:bg-gray-800 p-5 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700">
                    <h3 class="text-sm font-bold text-gray-700 dark:text-gray-300 mb-4 text-center">Desglose por
                        Categoría</h3>
                    <div class="relative h-64 w-full flex justify-center">
                        <canvas id="categoryChart"></canvas>
                    </div>
                </div>
                <div
                    class="bg-white dark:bg-gray-800 p-5 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700">
                    <h3 class="text-sm font-bold text-gray-700 dark:text-gray-300 mb-4 text-center">Tendencia de
                        Vencidos</h3>
                    <div class="relative h-64 w-full flex justify-center">
                        <canvas id="expiredChart"></canvas>
                    </div>
                </div>
            </div>

            <div
                class="mt-8 bg-gradient-to-r from-red-50 to-orange-50 dark:from-red-900/20 dark:to-orange-900/20 rounded-2xl p-5 flex flex-col sm:flex-row items-center justify-between gap-4 border border-red-100 dark:border-red-800/30">
                <div>
                    <h3 class="font-bold text-red-800 dark:text-red-400 flex items-center gap-2 text-lg">
                        <i class="fa-solid fa-money-bill-trend-up"></i> Pérdida Económica Estimada
                    </h3>
                    <p class="text-sm text-red-600 dark:text-red-300 mt-1">Suma del valor de productos desperdiciados en
                        el historial.</p>
                </div>
                <div class="text-3xl font-black text-red-600 dark:text-red-400" id="stat-loss">$0.00</div>
            </div>
        </section>

        <!-- View: Inventory List -->
        <section id="view-inventory" class="view-section hidden animate-fade-in">
            <div class="mb-6 flex flex-col sm:flex-row sm:justify-between sm:items-end gap-4">
                <div>
                    <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Inventario Actual</h2>
                    <p class="text-gray-600 dark:text-gray-400 text-sm">Gestiona y actualiza tus productos</p>
                </div>
                <div class="flex flex-col sm:flex-row gap-3 w-full sm:w-auto">
                    <select id="filter-category"
                        class="bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white text-sm rounded-xl focus:ring-brand-500 focus:border-brand-500 block w-full p-3 sm:p-2.5 shadow-sm">
                        <option value="all">Todas las Categorías</option>
                        <option value="Lácteos">Lácteos</option>
                        <option value="Carnes">Carnes</option>
                        <option value="Verduras">Verduras</option>
                        <option value="Bebidas">Bebidas</option>
                        <option value="Limpieza">Limpieza</option>
                        <option value="Otros">Otros</option>
                    </select>
                    <select id="filter-status"
                        class="bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white text-sm rounded-xl focus:ring-brand-500 focus:border-brand-500 block w-full p-3 sm:p-2.5 shadow-sm">
                        <option value="all">Todos los Estados</option>
                        <option value="safe">Seguros</option>
                        <option value="warning">Por Vencer</option>
                        <option value="danger">Vencidos</option>
                    </select>
                </div>
            </div>

            <!-- List Container -->
            <div id="inventory-list" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
                <!-- Loader placeholder -->
                <div class="col-span-full flex justify-center py-10">
                    <i class="fa-solid fa-spinner fa-spin text-3xl text-brand-500"></i>
                </div>
            </div>
        </section>

        <!-- View: History -->
        <section id="view-history" class="view-section hidden animate-fade-in">
            <div class="mb-6 flex flex-col sm:flex-row sm:justify-between sm:items-end gap-4">
                <div>
                    <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Historial</h2>
                    <p class="text-gray-600 dark:text-gray-400 text-sm">Registro de consumo y desperdicio</p>
                </div>
                <div class="flex gap-3 w-full sm:w-auto">
                    <button id="btn-export-excel"
                        class="flex-1 bg-green-600 hover:bg-green-700 text-white rounded-xl px-4 py-3 sm:py-2.5 hover:shadow-lg hover:-translate-y-0.5 transition-all flex items-center justify-center gap-2 text-sm font-medium">
                        <i class="fa-solid fa-file-excel text-lg"></i> <span>Exportar</span>
                    </button>
                    <button id="btn-import-excel"
                        class="flex-1 bg-blue-600 hover:bg-blue-700 text-white rounded-xl px-4 py-3 sm:py-2.5 hover:shadow-lg hover:-translate-y-0.5 transition-all flex items-center justify-center gap-2 text-sm font-medium">
                        <i class="fa-solid fa-file-import text-lg"></i> <span>Importar</span>
                    </button>
                    <!-- Input oculto para archivo excel -->
                    <input type="file" id="excel-file-input" class="hidden" accept=".xlsx, .xls">
                </div>
            </div>

            <!-- History List -->
            <div
                class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-sm text-left text-gray-500 dark:text-gray-400">
                        <thead
                            class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-gray-700/50 dark:text-gray-400">
                            <tr>
                                <th scope="col" class="px-6 py-4 rounded-tl-lg">Producto</th>
                                <th scope="col" class="px-6 py-4 hidden sm:table-cell">Categoría</th>
                                <th scope="col" class="px-6 py-4 text-center">Resultado</th>
                                <th scope="col" class="px-6 py-4 text-right rounded-tr-lg">Pérdida</th>
                            </tr>
                        </thead>
                        <tbody id="history-list">
                            <!-- Items injected here -->
                            <tr class="border-b dark:border-gray-700">
                                <td colspan="4" class="px-6 py-12 text-center">
                                    <i class="fa-solid fa-spinner fa-spin text-2xl text-brand-500"></i>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

    </main>

    <!-- Bottom Navigation -->
    <nav
        class="fixed bottom-0 left-0 right-0 bg-white/95 dark:bg-gray-800/95 backdrop-blur-lg border-t border-gray-200 dark:border-gray-700 z-40 pb-safe shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.05)]">
        <div class="container mx-auto max-w-md px-6 flex justify-between items-center h-16 relative">

            <button
                class="nav-btn active flex flex-col items-center justify-center w-16 h-full text-gray-400 transition-colors"
                data-target="view-dashboard">
                <i class="fa-solid fa-chart-pie text-xl mb-1 transition-transform"></i>
                <span class="text-[10px] font-semibold">Dashboard</span>
            </button>

            <button
                class="nav-btn flex flex-col items-center justify-center w-16 h-full text-gray-400 transition-colors"
                data-target="view-inventory">
                <i class="fa-solid fa-layer-group text-xl mb-1 transition-transform"></i>
                <span class="text-[10px] font-semibold">Lista</span>
            </button>

            <!-- Spacer for FAB -->
            <div class="w-16"></div>

            <button
                class="nav-btn flex flex-col items-center justify-center w-16 h-full text-gray-400 transition-colors"
                data-target="view-history">
                <i class="fa-solid fa-clock-rotate-left text-xl mb-1 transition-transform"></i>
                <span class="text-[10px] font-semibold">Historial</span>
            </button>
        </div>
    </nav>

    <!-- Floating Action Button -->
    <button id="btn-add"
        class="fixed bottom-6 left-1/2 -translate-x-1/2 w-16 h-16 bg-brand-500 hover:bg-brand-600 text-white rounded-full shadow-[0_8px_30px_rgb(16,185,129,0.4)] flex items-center justify-center text-2xl z-50 transform hover:scale-110 active:scale-95 transition-all duration-200 border-4 border-white dark:border-gray-900">
        <i class="fa-solid fa-plus"></i>
    </button>

    <!-- Modal: Add Product -->
    <div id="modal-add" class="fixed inset-0 z-[60] hidden opacity-0 transition-opacity duration-300">
        <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" id="modal-bg"></div>
        <div class="absolute inset-x-0 bottom-0 bg-white dark:bg-gray-800 rounded-t-[2.5rem] shadow-2xl transform transition-transform duration-300 translate-y-full flex flex-col max-h-[90vh]"
            id="modal-panel">
            <div class="w-full flex justify-center pt-4 pb-2 shrink-0">
                <div class="w-16 h-1.5 bg-gray-300 dark:bg-gray-600 rounded-full"></div>
            </div>

            <div class="px-6 pb-6 overflow-y-auto pb-safe flex-1">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="text-2xl font-bold text-gray-900 dark:text-white" id="modal-title">Nuevo Producto</h3>
                    <button type="button" id="btn-close-modal"
                        class="text-gray-400 hover:text-gray-600 dark:hover:text-white">
                        <i class="fa-solid fa-xmark text-xl"></i>
                    </button>
                </div>

                <form id="product-form" class="space-y-5">
                    <input type="hidden" id="prod-id">

                    <div>
                        <label class="block mb-2 text-sm font-semibold text-gray-900 dark:text-gray-100">Código de
                            Barras</label>
                        <div class="flex gap-3">
                            <input type="text" id="prod-barcode"
                                class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-xl focus:ring-brand-500 focus:border-brand-500 block w-full p-4 dark:bg-gray-700/50 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white outline-none transition-shadow"
                                placeholder="Escanear o tipear...">
                            <button type="button" id="btn-scan"
                                class="bg-gray-800 dark:bg-gray-600 text-white px-5 rounded-xl hover:bg-gray-700 transition flex items-center justify-center shadow-md shrink-0">
                                <i class="fa-solid fa-barcode text-xl"></i>
                            </button>
                        </div>
                    </div>

                    <div>
                        <label class="block mb-2 text-sm font-semibold text-gray-900 dark:text-gray-100">Nombre del
                            Producto <span class="text-red-500">*</span></label>
                        <input type="text" id="prod-name" required
                            class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-xl focus:ring-brand-500 focus:border-brand-500 block w-full p-4 dark:bg-gray-700/50 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white outline-none transition-shadow"
                            placeholder="Ej: Leche Deslactosada">
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                        <div>
                            <label class="block mb-2 text-sm font-semibold text-gray-900 dark:text-gray-100">Categoría
                                <span class="text-red-500">*</span></label>
                            <select id="prod-category" required
                                class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-xl focus:ring-brand-500 focus:border-brand-500 block w-full p-4 dark:bg-gray-700/50 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white outline-none">
                                <option value="Lácteos">Lácteos</option>
                                <option value="Carnes">Carnes</option>
                                <option value="Verduras">Verduras</option>
                                <option value="Bebidas">Bebidas</option>
                                <option value="Limpieza">Limpieza</option>
                                <option value="Otros" selected>Otros</option>
                            </select>
                        </div>
                        <div>
                            <label class="block mb-2 text-sm font-semibold text-gray-900 dark:text-gray-100">Precio
                                <span class="text-gray-400 font-normal">(Opcional)</span></label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                    <span class="text-gray-500 sm:text-sm font-medium">$</span>
                                </div>
                                <input type="number" id="prod-price" step="0.01" min="0"
                                    class="pl-8 bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-xl focus:ring-brand-500 focus:border-brand-500 block w-full p-4 dark:bg-gray-700/50 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white outline-none"
                                    placeholder="0.00">
                            </div>
                        </div>
                    </div>

                    <div>
                        <label class="block mb-2 text-sm font-semibold text-gray-900 dark:text-gray-100">Fecha de
                            Vencimiento <span class="text-red-500">*</span></label>
                        <input type="date" id="prod-date" required
                            class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-xl focus:ring-brand-500 focus:border-brand-500 block w-full p-4 dark:bg-gray-700/50 dark:border-gray-600 dark:text-white outline-none">
                    </div>

                    <div class="pt-4 pb-2">
                        <button type="submit"
                            class="w-full text-white bg-brand-500 hover:bg-brand-600 font-bold rounded-xl text-lg px-5 py-4 transition-all shadow-lg shadow-brand-500/30 transform hover:-translate-y-0.5">Guardar
                            Producto</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Modal: Scanner (Full Screen) -->
    <div id="modal-scanner"
        class="fixed inset-0 z-[70] hidden bg-black flex-col opacity-0 transition-opacity duration-300">
        <div
            class="px-5 py-4 flex justify-between items-center bg-black/60 text-white z-10 w-full absolute top-0 backdrop-blur-md">
            <h3 class="font-bold text-lg"><i class="fa-solid fa-expand mr-2"></i> Escanear Código</h3>
            <button id="btn-close-scanner"
                class="p-2 bg-white/10 rounded-full hover:bg-white/20 transition w-10 h-10 flex items-center justify-center">
                <i class="fa-solid fa-xmark text-xl"></i>
            </button>
        </div>
        <div class="flex-1 w-full relative flex items-center justify-center overflow-hidden bg-gray-900"
            id="scanner-container">
            <div id="reader" class="w-full max-w-lg mx-auto overflow-hidden rounded-2xl shadow-2xl"></div>
        </div>
        <div class="p-6 bg-black/80 backdrop-blur text-white text-center text-sm pb-safe z-10 w-full">
            <p class="font-medium">Alinea el código de barras dentro del recuadro</p>
        </div>
    </div>

    <!-- Scripts CDN -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://unpkg.com/html5-qrcode" type="text/javascript"></script>
    <script src="https://cdn.sheetjs.com/xlsx-latest/package/dist/xlsx.full.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <!-- Main Script -->
    <script type="module" src="script.js"></script>
</body>

</html>